# ByteTaper Production Environment Configuration Reference (TEMPLATE)
# ==================================================================
# NOTE: This file is a template. To use it with Docker Compose, copy it to 
# '.env' in your deployment directory or supply it via '--env-file'.

# -- Core Settings --
# BYTETAPER_VERSION: Used for tagging/versioning in logs (default: dev)
# BYTETAPER_GIT_SHA: Used for traceability in logs (default: unknown)

# -- L2 Cache (RocksDB) Tuning --
# Block Cache: LRU cache for data blocks. Higher is better for read performance.
BYTETAPER_L2_BLOCK_CACHE_MB=64

# Write Buffer: Size of the memtable. Higher allows faster write bursts.
BYTETAPER_L2_WRITE_BUFFER_MB=32

# Max Background Jobs: Concurrent flush and compaction jobs.
BYTETAPER_L2_MAX_BACKGROUND_JOBS=2

# -- Worker & Queue Tuning --
# Worker Count: Number of background threads processing L2 IO and coalescing.
BYTETAPER_WORKER_COUNT=2

# Lookup Lane Quota: Max concurrent L2 lookups per scheduling cycle.
BYTETAPER_LOOKUP_LANE_QUOTA=4

# Store Lane Quota: Max concurrent L2 stores per scheduling cycle.
BYTETAPER_STORE_LANE_QUOTA=1

# Async Store Max Body Size: Optional override for the max body size (bytes) stored in L2.
# When unset, derived from route max_response_bytes, capped at 1 MiB.
# Uncomment to set an explicit cap (e.g. to limit memory/disk pressure):
# BYTETAPER_ASYNC_STORE_MAX_BODY_SIZE=1048576

# -- NOTE ON ADMIN ENDPOINT --
# The admin endpoint is NOT enabled via environment variables.
# To enable it in Docker Compose, you must use a 'docker-compose.override.yml'
# as documented in the GA_RUNBOOK.md "Enable or Disable Admin Endpoint" section.

# -- Runtime Paths (Internal Container Paths) --
# BYTETAPER_POLICY_PATH=/etc/bytetaper/policy.yaml
# BYTETAPER_L2_CACHE_PATH=/var/lib/bytetaper/l2-cache
